[global]
    monitor = 0
    follow = mouse
    width = (0, 500)
    height = 200
    origin = top-right
    offset = 10x40
    transparency = 10
    corner_radius = 8
    frame_width = 2
    frame_color = "#942f99"
    #font = Monospace 9 
    font = VictorMono Nerd Font 10
    separator_height = 2
    padding = 8
    horizontal_padding = 10
    icon_position = left
    max_icon_size = 24
    markup = full
    word_wrap = true
    ellipsize = middle
    alignment = left
    show_age_threshold = 60
    sort = yes
    idle_threshold = 120
    line_height = 0
    separator_color = frame
    stack_duplicates = true
    icon_theme = "Nerd"

[urgency_low]
    background = "#1e1e1e"         # тёмный как старинный замок
    foreground = "#cccccc"         # тусклый свет свечи
    frame_color = "#44475a"        # холодный серо-стальной ободок
    timeout = 5

[urgency_normal]
    background = "#1b1b1b"         # мрачнее ночи
    foreground = "#e0e0e0"         # бледная луна
    frame_color = "#6e4b9e"        # фиолетовый отголосок витражей собора
    timeout = 8


[urgency_critical]
    background = "#121212"         # тьма склепа
    foreground = "#ff4444"         # крик на фоне молчания
    frame_color = "#990000"        # глубокая кровь, насыщенная
    timeout = 0
